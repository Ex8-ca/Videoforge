# ============================================================
# videoforge configuration
# ============================================================
# Copy this file to `.env` and fill in your real values.
# NEVER commit `.env` to git — it is already in `.gitignore`.

# ------------------------------------------------------------
# MiniMax (cloud video generation) — REQUIRED
# ------------------------------------------------------------
# Required. The server refuses to start without this key.
# Get one at https://platform.minimax.io/user-center/basic-information/interface-key
#
# The server reads `MINIMAX_API_VIDEOFORGE` first (so each app
# can have its own key), then falls back to `MINIMAX_API_KEY`.

MINIMAX_API_VIDEOFORGE=your_minimax_videoforge_key_here
MINIMAX_API_KEY=your_minimax_key_here

# ------------------------------------------------------------
# Cloudinary (video history uploads) — OPTIONAL
# ------------------------------------------------------------
# Used for the "Upload to Cloudinary" button on saved videos.
# Sign up at https://cloudinary.com and grab these from the
# console's "Account Details" section.
#
# Threat model:
#   * The browser needs `CLOUDINARY_CLOUD_NAME` (public) and
#     `CLOUDINARY_UPLOAD_PRESET` to perform UNSIGNED uploads
#     directly to Cloudinary. These two are exposed via the
#     `GET /api/cloudinary-config` endpoint.
#   * `CLOUDINARY_API_KEY` and `CLOUDINARY_API_SECRET` stay
#     SERVER-SIDE only. They are used by the server for signed
#     operations (delete, listing, transformations). The
#     endpoint above NEVER returns them.
#
# Rotation: if these leak, regenerate them in the Cloudinary
# console — you do NOT need to change anything in this repo.

CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here
CLOUDINARY_UPLOAD_PRESET=your_upload_preset_here

# ------------------------------------------------------------
# Together.ai (optional alternative video backend)
# ------------------------------------------------------------
# Used by the Together.ai proxy. Leave empty if you do not use
# the Together backend.
# Get a key at https://api.together.xyz/settings/api-keys

TOGETHER_API_KEY=your_together_api_key_here